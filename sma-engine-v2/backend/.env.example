# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://smaengine:yourpassword@localhost:5432/smaengine
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smaengine
DB_USER=smaengine
DB_PASSWORD=yourpassword

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# Single-user auth key — set a long random string, use in API requests as:
# Authorization: Bearer YOUR_AUTH_KEY
AUTH_KEY=change_this_to_a_long_random_string_minimum_32_chars

# ── MARKET DATA API ───────────────────────────────────────────────────────────
# Polygon.io / Massive Stocks Starter API key
POLYGON_API_KEY=your_polygon_api_key_here
POLYGON_BASE_URL=https://api.polygon.io

# ── EMAIL (Resend — free 3,000/month at resend.com) ───────────────────────────
RESEND_API_KEY=re_your_resend_key_here
EMAIL_FROM=alerts@yourdomain.com
EMAIL_TO=you@youremail.com
# Optional: comma-separated for multiple recipients
# EMAIL_TO=you@email.com,partner@email.com

# ── SCAN CONFIGURATION ────────────────────────────────────────────────────────
DEFAULT_TIER=T1
DEFAULT_BATCH_SIZE=50
DEFAULT_BATCH_DELAY_MS=120
# Liquidity defaults
LIQ_MIN_PRICE=2
LIQ_MIN_AVG_VOL=250000
LIQ_MIN_DOLLAR_VOL=5000000
LIQ_MIN_HISTORY_DAYS=60

# ── BACKUP (Backblaze B2 — optional) ─────────────────────────────────────────
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=sma-engine-backups

# ── SCHEDULER ─────────────────────────────────────────────────────────────────
# Set to 'true' to enable all scheduled jobs
SCHEDULER_ENABLED=true
# Timezone for all cron expressions
TZ=America/New_York

# ── FRONTEND URL (for CORS) ───────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
